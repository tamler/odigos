# Odigos Configuration
# Copy this to config.yaml and fill in your values.

# API key for authenticating dashboard and API requests.
# If not set, a random key is generated on first startup and saved.
# api_key: "your-secret-api-key-here"

agent:
  name: "Odigos"
  max_tool_turns: 10
  run_timeout_seconds: 120

database:
  path: "data/odigos.db"

# LLM provider (any OpenAI-compatible API)
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
#   vLLM:        http://localhost:8000/v1
llm:
  base_url: "https://openrouter.ai/api/v1"
  default_model: "deepseek/deepseek-v3.2"
  fallback_model: "google/gemini-2.5-flash"
  max_tokens: 4096
  temperature: 0.7

# Budget limits (USD)
budget:
  daily_limit_usd: 5.0
  monthly_limit_usd: 50.0
  warn_threshold: 0.8

# Web server
server:
  host: "0.0.0.0"
  port: 8000

# Heartbeat (autonomous background loop)
heartbeat:
  interval_seconds: 30
  max_todos_per_tick: 3
  idle_think_interval: 900

# Features (all enabled by default, disable with enabled: false)
notebooks:
  enabled: true

kanban:
  enabled: true

# Agent mesh networking
mesh:
  enabled: false

# Peer agents (requires mesh.enabled: true)
# peers:
#   - name: "researcher"
#     netbird_ip: "100.64.0.2"
#     ws_port: 8001
#     api_key: "peer-secret"

# Email integration (optional)
# email:
#   enabled: true
#   address: "agent@yourdomain.com"
#   imap_host: "mail.yourdomain.com"
#   imap_port: 993
#   smtp_host: "mail.yourdomain.com"
#   smtp_port: 587
#   username: "agent@yourdomain.com"
#   password: "from-env-var"
#   check_interval_ticks: 10

# Telegram bot (optional)
# telegram:
#   mode: "polling"

# SearXNG search (optional)
# searxng_url: "http://searxng:8080"

# Google Workspace CLI (optional, requires gcloud setup)
gws:
  enabled: false

# Agent Browser CLI (optional)
browser:
  enabled: false

# Voice (optional, requires moonshine-voice and pocket-tts)
stt:
  enabled: false
tts:
  enabled: false

# File tool sandbox
file_access:
  allowed_paths:
    - "data/files"

# Tool approval gate (optional)
approval:
  enabled: false
  timeout: 300
  tools: []

# Code sandbox
sandbox:
  timeout_seconds: 5
  max_memory_mb: 512
  allow_network: false

# MCP servers (optional)
# mcp:
#   servers:
#     myserver:
#       command: "npx"
#       args: ["-y", "@my/mcp-server"]

# Skills directory
skills:
  path: "skills"

# Evolution engine
evolution:
  trial_duration_hours: 48
  min_evaluations: 5
  promote_threshold: 0.5
  revert_threshold: -0.3
