agent:
  name: "Odigos"

database:
  path: "data/odigos.db"

openrouter:
  default_model: "anthropic/claude-sonnet-4"
  fallback_model: "google/gemini-2.0-flash-001"
  max_tokens: 4096
  temperature: 0.7

telegram:
  mode: "polling"
  webhook_url: ""

server:
  host: "127.0.0.1"
  port: 8000

gws:
  enabled: false
  timeout: 30

browser:
  enabled: false
  timeout: 120
