# Odigos Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider (required) ─────────────────────────────────────────
# API key for your LLM provider (OpenRouter, OpenAI, etc.)
LLM_API_KEY=your-api-key

# Base URL for any OpenAI-compatible API
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Default model for agent tasks
LLM_DEFAULT_MODEL=deepseek/deepseek-v3.2

# Fallback model (used when default is unavailable or for cheaper tasks)
LLM_FALLBACK_MODEL=google/gemini-2.5-flash

# ── Authentication (required) ───────────────────────────────────────
# API key for authenticating dashboard and API access.
# install.sh generates one automatically if not set.
API_KEY=

# ── Server ──────────────────────────────────────────────────────────
# Port the Odigos server listens on inside the container
ODIGOS_PORT=8000

# ── TLS / Reverse Proxy ────────────────────────────────────────────
# Domain name for automatic HTTPS via Caddy (e.g. agent.example.com).
# Leave as localhost for local development (self-signed cert).
ODIGOS_DOMAIN=localhost

# ── Telegram (optional) ────────────────────────────────────────────
# Uncomment and set to enable the Telegram bot channel
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
